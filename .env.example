# Copy this file to .env and fill in your Firecrawl API key.
# Get a free key at https://firecrawl.dev
#
# Note: The /job-scraper skill saves your key in config.json automatically
# on first run — you do not need to create this file manually unless you
# want to run job_scraper.py directly from the command line.

FIRECRAWL_API_KEY=your_api_key_here
